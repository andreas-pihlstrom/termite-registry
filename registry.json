      "sha256": "44ec2617865ea12ede959351d08c9439da1e928ffaed7029c4b761efd78b7feb",
      "sdk": "v1",
      "capabilities": [
        "channels",
        "events.read"
      ]
    },
    {
      "kind": "channel",
      "id": "dev.termite.command-queue",
      "name": "Command Queue",
      "description": "Bridge an explicitly configured JSON producer and consumer through Termite's reviewed Work Inbox",
      "mode": "two-way",
      "setup": "Producer and consumer argv arrays",
      "configuration": {
        "version": 1,
        "fields": [
          {
            "key": "enabled",
            "label": "Enable command queue",
            "type": "boolean",
            "required": true,
            "default": true
          },
          {
            "key": "producer",
            "label": "Producer argv",
            "type": "json",
            "required": true,
            "placeholder": "[\"/absolute/path/to/producer\"]"
          },
          {
            "key": "consumer",
            "label": "Consumer argv",
            "type": "json",
            "required": true,
            "placeholder": "[\"/absolute/path/to/consumer\"]"
          }
        ]
      },
      "author": "termite",
      "license": "MIT",
