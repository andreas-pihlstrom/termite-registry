    {
      "kind": "channel",
      "id": "dev.termite.imap-mail",
      "name": "IMAP Mail",
      "description": "Poll an IMAP mailbox and optionally send explicitly approved replies with SMTP",
      "mode": "two-way",
      "setup": "IMAP account; SMTP optional",
      "configuration": {
        "version": 1,
        "fields": [
          {
            "key": "imap_host",
            "label": "IMAP host",
            "type": "text",
            "required": true,
            "placeholder": "imap.example.com"
          },
          {
            "key": "username",
            "label": "IMAP username",
            "type": "text",
            "required": true,
            "placeholder": "you@example.com"
          },
          {
            "key": "password",
            "label": "IMAP password",
            "type": "secret",
            "required": true,
            "keychainService": "termite.imap-mail"
          },
          {
            "key": "mailbox",
            "label": "Mailbox",
            "type": "text",
            "required": false,
            "default": "INBOX"
          },
          {
            "key": "smtp_host",
            "label": "SMTP host",
            "type": "text",
            "required": false,
            "placeholder": "smtp.example.com",
            "help": "Optional; required only for approved replies."
          },
          {
            "key": "smtp_username",
            "label": "SMTP username",
            "type": "text",
            "required": false,
            "placeholder": "you@example.com"
          },
          {
            "key": "smtp_password",
            "label": "SMTP password",
            "type": "secret",
            "required": false,
            "keychainService": "termite.imap-mail.smtp"
          },
          {
            "key": "from_address",
            "label": "From address",
            "type": "text",
            "required": false,
            "placeholder": "you@example.com"
