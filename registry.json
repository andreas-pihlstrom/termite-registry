    {
      "kind": "channel",
      "id": "dev.termite.apple-reminders",
      "name": "Apple Reminders",
      "description": "Read incomplete reminders from explicitly allowlisted Apple Reminders lists into the Work Inbox",
      "mode": "read-only",
      "setup": "macOS Reminders list allowlist",
      "configuration": {
        "version": 1,
        "fields": [
          {
            "key": "enabled",
            "label": "Enable Reminders access",
            "type": "boolean",
            "required": true,
            "default": true
          },
          {
            "key": "allowedListNames",
            "label": "Allowed list names",
            "type": "string-list",
            "required": true,
            "placeholder": "Work, Termite",
            "help": "Only these Reminders lists are read."
          }
        ]
      },
      "author": "termite",
      "license": "MIT",
      "version": "1.1.0",
      "homepage": "https://github.com/andreas-pihlstrom/termite-registry/tree/main/plugins/apple-reminders",
      "file": "dist/apple-reminders-1.1.0.zip",
      "sha256": "8a88c72fa444e0aa5f38585bb1be8804e5e5f518f326c15d46cbbb3ecc8117f1",
      "sdk": "v1",
      "capabilities": [
        "channels"
      ]
    },
    {
      "kind": "channel",
      "id": "dev.termite.clipboard-inbox",
      "name": "Clipboard Inbox",
      "description": "Opt-in macOS clipboard changes as reviewable work, with separately approved clipboard replies",
      "mode": "two-way",
      "setup": "Explicit macOS clipboard opt-in",
      "configuration": {
        "version": 1,
        "fields": [
          {
            "key": "enabled",
            "label": "Enable connector",
            "type": "boolean",
            "required": true,
            "default": true
          },
          {
            "key": "pollClipboard",
            "label": "Read clipboard changes",
            "type": "boolean",
            "required": true,
            "default": true
          },
          {
            "key": "writeApprovedReplies",
            "label": "Write approved replies",
            "type": "boolean",
            "required": false,
            "default": false,
            "help": "Off by default; enabling replaces the current clipboard on delivery."
          }
        ]
      },
      "author": "termite",
      "license": "MIT",
      "version": "1.1.0",
      "homepage": "https://github.com/andreas-pihlstrom/termite-registry/tree/main/plugins/clipboard-inbox",
